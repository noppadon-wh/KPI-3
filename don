function selectLatestPeriod(){
  if(!DATA_ROWS.length) return;
  const latestYear = Math.max(...DATA_ROWS.map(row => row.year));
  const yearRows = DATA_ROWS.filter(row => row.year === latestYear);
  const latestWeek = Math.max(...yearRows.map(row => row.week));
  const latestRows = yearRows.filter(row => row.week === latestWeek);
  state.year = latestYear;
  state.week = latestWeek;
  state.month = monthOrder.find(month => latestRows.some(row => row.month === month)) || latestRows[0].month;
}

