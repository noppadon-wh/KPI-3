function getYearsPresent(){ const set = new Set(DATA_ROWS.map(r => r.year)); return [...set].sort((a,b) => a-b); }
function getMonthsPresent(year){ const set = new Set(DATA_ROWS.filter(r => year === "ทั้งหมด" || r.year === year).map(r => r.month)); return monthOrder.filter(m => set.has(m)); }
function getWeeksForMonth(year, month){ const set = new Set(DATA_ROWS.filter(r => (year === "ทั้งหมด" || r.year === year) && (month === "ทั้งหมด" || r.month === month)).map(r => r.week)); return [...set].sort((a,b) => a-b); }

