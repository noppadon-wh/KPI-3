  }
  .kpi-card .label{
    font-size:13px;
    color:var(--text-secondary);
    margin:0 0 10px;
    font-weight:500;
  }
  .kpi-card .value{
    font-size:32px;
    font-weight:700;
    margin:0;
    letter-spacing:-0.01em;
  }
  .kpi-card .sub{
    font-size:12.5px;
    color:var(--text-muted);
    margin:8px 0 0;
  }
  .kpi-card.c-total{--accent:#1baf7a;}
  .kpi-card.c-in{--accent:#3987e5;}
  .kpi-card.c-store{--accent:#eda100;}
  .kpi-card.c-time{--accent:#6c63d9;}
  .charts-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:16px;
    margin-bottom:24px;
  }
  .panel{
    background:linear-gradient(180deg, var(--bg-2), var(--bg-1));
    border:1px solid var(--card-border);
    border-radius:var(--radius);
    padding:20px 22px 16px;
