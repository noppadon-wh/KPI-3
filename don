      <p class="sub" id="kpiStoreSub">สถานะจาก Google Sheets</p>
    </div>
    <div class="kpi-card c-time">
      <p class="label">เวลาเฉลี่ยรวม (วัน)</p>
      <p class="value" id="kpiTime">-</p>
