<script>
const DATA_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vT1lgAWEGk3qFzUO2Iok3CZrKP7Zu3Gd9gxvUsfR-Y9p4YQm7GXh0wxKWfIEnZZWLYwYKaTIp1E1vDq/pub?gid=1625574187&single=true&output=csv";
const monthOrder = ["มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน","กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"];
let DATA_ROWS = [];
let state = { year: "ทั้งหมด", month: "ทั้งหมด", week: "ทั้งหมด" };
let chartTypeInst = null, chartLeadInst = null;

// ฟังก์ชันช่วยค้นหาคีย์ข้อมูลแบบยืดหยุ่น (ไม่สนใจ Spacebar และ ตัวพิมพ์เล็ก-ใหญ่)
function getRowValue(row, possibleKeys) {
  const rowKeys = Object.keys(row);
  for (let pk of possibleKeys) {
    const normalizedPk = pk.trim().toLowerCase().replace(/\s+/g, '');
    const foundKey = rowKeys.find(rk => rk.trim().toLowerCase().replace(/\s+/g, '') === normalizedPk);
    if (foundKey) return row[foundKey];
  }
  return '';
}

function parseCsv(text){
  const records = [];
  let record = [], field = '', quoted = false;
  for(let i = 0; i < text.length; i++){
    const char = text[i];
    if(quoted){
      if(char === '"' && text[i + 1] === '"'){
        field += '"';
        i++;
      }else if(char === '"'){
        quoted = false;
      }else{
        field += char;
      }
    }else if(char === '"'){
      quoted = true;
    }else if(char === ','){
      record.push(field);
      field = '';
    }else if(char === '\n'){
      record.push(field.replace(/\r$/, ''));
      records.push(record);
      record = [];
      field = '';
    }else{
      field += char;
    }
  }
  if(field || record.length){
    record.push(field.replace(/\r$/, ''));
    records.push(record);
  }
  const headers = records.shift()?.map(header => header.trim()) || [];
  return records.map(values => Object.fromEntries(headers.map((header, index) => [header, (values[index] || '').trim()])));
}

// ระบบแกะวันที่แบบยืดหยุ่นสูง (แก้ปัญหาเรื่องวินาที และ ปี พ.ศ.)
function parseSheetDate(value){
  if (!value) return null;
  value = value.trim();
  
  // รูปแบบ DD/MM/YYYY พร้อมเวลา (มีหรือไม่มีวินาทีก็ได้)
  const dmyMatch = value.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4}|\d{2})(?:\s+(\d{1,2}):(\d{2})(?::(\d{2}))?)?$/);
  if (dmyMatch) {
    let day = Number(dmyMatch[1]);
    let month = Number(dmyMatch[2]) - 1;
    let year = Number(dmyMatch[3]);
    if (year < 100) year += 2000;
    if (year > 2400) year -= 543; // แปลง พ.ศ. เป็น ค.ศ.
    
    let hour = Number(dmyMatch[4] || 0);
    let min = Number(dmyMatch[5] || 0);
    let sec = Number(dmyMatch[6] || 0);
    return new Date(year, month, day, hour, min, sec);
  }
  
  // รูปแบบ YYYY-MM-DD (ค.ศ. หรือ พ.ศ.)
  const ymdMatch = value.match(/^(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})(?:\s+(\d{1,2}):(\d{2})(?::(\d{2}))?)?$/);
  if (ymdMatch) {
    let year = Number(ymdMatch[1]);
    if (year > 2400) year -= 543; // แปลง พ.ศ. เป็น ค.ศ.
    let month = Number(ymdMatch[2]) - 1;
    let day = Number(ymdMatch[3]);
    let hour = Number(ymdMatch[4] || 0);
    let min = Number(ymdMatch[5] || 0);
    let sec = Number(ymdMatch[6] || 0);
    return new Date(year, month, day, hour, min, sec);
  }

  // ตัวช่วยสุดท้ายลองแปลงผ่าน Native Javascript
  const nativeParse = new Date(value);
  if (!isNaN(nativeParse.getTime())) {
    if (nativeParse.getFullYear() > 2400) {
      nativeParse.setFullYear(nativeParse.getFullYear() - 543);
    }
    return nativeParse;
  }
  
  return null;
}

function formatDate(date){
  if(!date) return '-';
  const pad = value => String(value).padStart(2, '0');
  return `${pad(date.getDate())}/${pad(date.getMonth() + 1)}/${date.getFullYear()}`;
}

function differenceInDays(start, end){
  if(!start || !end) return 0;
  return (end.getTime() - start.getTime()) / 86400000;
}

function isPassing(value){
  if(!value) return false;
  return value.includes('ผ่าน') && !value.includes('ไม่ผ่าน');
}

function toDashboardRow(row, index){
  // เรียกดึงข้อมูลแบบยืดหยุ่น รองรับการสะกดหัวตารางคลาดเคลื่อน
  const rawWeek = getRowValue(row, ['Week', 'สัปดาห์', 'Wk']);
  const week = Number(rawWeek);
  
  const rawArrive = getRowValue(row, ['วันที่ของมาส่ง', 'วันที่มาส่ง', 'Arrive Date']);
  const rawEntered = getRowValue(row, ['วันที่รับเข้าระบบ', 'วันรับเข้าระบบ', 'Entered Date']);
  const rawStored = getRowValue(row, ['วันที่จัดเก็บ', 'วันจัดเก็บ', 'Stored Date']);
  
  const arriveDate = parseSheetDate(rawArrive);
  const enteredDate = parseSheetDate(rawEntered);
  const storedDate = parseSheetDate(rawStored);
  
  const month = getRowValue(row, ['Month', 'เดือน']);
  const lot = getRowValue(row, ['Lot/Serial Number', 'Lot / Serial Number', 'Lot/Serial', 'Lot', 'Serial']);
  
  // แจ้งเตือนใน Console เผื่อข้อมูลสำคัญว่างเปล่า
  if(!lot) {
    console.warn(`⚠️ แถวที่ ${index + 2} ถูกข้าม: ไม่มีข้อมูล Lot/Serial`);
    return null;
  }
  if(!arriveDate || !enteredDate || !storedDate) {
    console.warn(`⚠️ แถวที่ ${index + 2} ถูกข้าม: วันที่อ่านค่าไม่ได้ (Arrive: "${rawArrive}", Entered: "${rawEntered}", Stored: "${rawStored}")`);
    return null;
  }

  return {
    year: arriveDate.getFullYear(),
    week: isNaN(week) ? 0 : week,
    month: month || 'ไม่ระบุ',
    lot: lot,
    product: getRowValue(row, ['Product', 'สินค้า', 'ชื่อสินค้า']) || '-',
    to: getRowValue(row, ['To', 'ปลายทาง', 'Destination']) || '-',
    arrive: formatDate(arriveDate),
    entered: formatDate(enteredDate),
    stored: formatDate(storedDate),
    lt_in: differenceInDays(arriveDate, enteredDate),
    lt_store: differenceInDays(enteredDate, storedDate),
    sla: getRowValue(row, ['วันที่ QA ใช้ตรวจ', 'SLA', 'QA']) || '-',
    type: getRowValue(row, ['Type', 'ประเภท']) || 'อื่นๆ',
    pass_in: isPassing(getRowValue(row, ['เกณฑ์รับเข้า', 'รับเข้าผ่านเกณฑ์'])),
    pass_store: isPassing(getRowValue(row, ['เกณฑ์จัดเก็บ', 'จัดเก็บผ่านเกณฑ์'])),
    pass_total: isPassing(getRowValue(row, ['เกณฑ์รวม', 'รวมผ่านเกณฑ์']))
  };
}

function selectLatestPeriod(){
  if(!DATA_ROWS.length) return;
  const latestYear = Math.max(...DATA_ROWS.map(row => row.year));
  const yearRows = DATA_ROWS.filter(row => row.year === latestYear);
  const latestWeek = Math.max(...yearRows.map(row => row.week));
  const latestRows = yearRows.filter(row => row.week === latestWeek);
  state.year = latestYear;
  state.week = latestWeek;
  state.month = monthOrder.find(month => latestRows.some(row => row.month === month)) || latestRows[0].month;
}

function escapeHtml(value){
  return String(value).replace(/[&<>'"]/g, char => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#39;', '"':'&quot;' })[char]);
}

function getYearsPresent(){
  const set = new Set(DATA_ROWS.map(r => r.year));
  return [...set].sort((a,b) => a-b);
}

function getMonthsPresent(year){
  const set = new Set(DATA_ROWS.filter(r => year === "ทั้งหมด" || r.year === year).map(r => r.month));
  return monthOrder.filter(m => set.has(m));
}

function getWeeksForMonth(year, month){
  const set = new Set(DATA_ROWS.filter(r => (year === "ทั้งหมด" || r.year === year) && (month === "ทั้งหมด" || r.month === month)).map(r => r.week));
  return [...set].sort((a,b) => a-b);
}

function renderYearFilters(){
  const el = document.getElementById('yearFilters');
  const years = ["ทั้งหมด", ...getYearsPresent()];
  el.innerHTML = "";
  years.forEach(y => {
    const btn = document.createElement('button');
    btn.className = 'chip year-active' + (state.year === y ? ' active' : '');
    btn.textContent = y;
    btn.onclick = () => {
      state.year = y;
      const months = getMonthsPresent(y);
      if(state.month !== "ทั้งหมด" && !months.includes(state.month)) state.month = "ทั้งหมด";
      const weeks = getWeeksForMonth(state.year, state.month);
      if(state.week !== "ทั้งหมด" && !weeks.includes(state.week)) state.week = "ทั้งหมด";
      renderYearFilters();
      renderMonthFilters();
      renderWeekFilters();
      update();
    };
    el.appendChild(btn);
  });
}

function renderMonthFilters(){
  const el = document.getElementById('monthFilters');
  const months = ["ทั้งหมด", ...getMonthsPresent(state.year)];
  el.innerHTML = "";
  months.forEach(m => {
    const btn = document.createElement('button');
    btn.className = 'chip month-active' + (state.month === m ? ' active' : '');
    btn.textContent = m;
    btn.onclick = () => {
      state.month = m;
      const weeks = getWeeksForMonth(state.year, m);
      if(!weeks.includes(state.week)) state.week = "ทั้งหมด";
      renderMonthFilters();
      renderWeekFilters();
      update();
    };
    el.appendChild(btn);
  });
}

function renderWeekFilters(){
  const el = document.getElementById('weekFilters');
  const weeks = ["ทั้งหมด", ...getWeeksForMonth(state.year, state.month)];
  el.innerHTML = "";
  weeks.forEach(w => {
    const btn = document.createElement('button');
    btn.className = 'chip' + (state.week === w ? ' active' : '');
    btn.textContent = w === "ทั้งหมด" ? "ทั้งหมด" : ("W" + w);
    btn.onclick = () => {
      state.week = w;
      renderWeekFilters();
      update();
    };
    el.appendChild(btn);
  });
}

function filteredRows(){
  return DATA_ROWS.filter(r => {
    if(state.year !== "ทั้งหมด" && r.year !== state.year) return false;
    if(state.month !== "ทั้งหมด" && r.month !== state.month) return false;
    if(state.week !== "ทั้งหมด" && r.week !== state.week) return false;
    return true;
  });
}

function pct(n, d){ return d === 0 ? 0 : Math.round((n/d)*1000)/10; }

function update(){
  const rows = filteredRows();
  const n = rows.length;
  document.getElementById('rowCountLabel').textContent = n + ' รายการ';
  const yearLbl = state.year === "ทั้งหมด" ? "ทุกปี" : state.year;
  const monthLbl = state.month === "ทั้งหมด" ? "ทุกเดือน" : state.month;
  const weekLbl = state.week === "ทั้งหมด" ? "ทุกสัปดาห์" : ("Week " + state.week);
  document.getElementById('pageTitle').textContent = 'KPI รับเข้า → จัดเก็บสินค้า · ' + weekLbl + ' (' + monthLbl + ' ' + yearLbl + ')';
  
  if(n === 0){
    document.getElementById('kpiTotal').textContent = '-';
    document.getElementById('kpiIn').textContent = '-';
    document.getElementById('kpiStore').textContent = '-';
    document.getElementById('kpiTime').textContent = '-';
    document.getElementById('kpiTotalSub').textContent = 'ไม่มีข้อมูล';
    document.getElementById('kpiInSub').textContent = '';
    document.getElementById('tbody').innerHTML = '<tr><td colspan="14" class="empty-msg">ไม่มีข้อมูลในช่วงที่เลือก</td></tr>';
    if(chartTypeInst) chartTypeInst.destroy();
    if(chartLeadInst) chartLeadInst.destroy();
    return;
  }
  
  const passIn = rows.filter(r => r.pass_in).length;
  const passStore = rows.filter(r => r.pass_store).length;
  const passTotal = rows.filter(r => r.pass_total).length;
  const avgIn = rows.reduce((s,r) => s + r.lt_in, 0) / n;
  const avgStore = rows.reduce((s,r) => s + r.lt_store, 0) / n;
  const avgTotal = avgIn + avgStore;
  
  document.getElementById('kpiTotal').textContent = pct(passTotal, n) + '%';
  document.getElementById('kpiTotalSub').textContent = passTotal + ' / ' + n + ' รายการผ่านเกณฑ์รวม';
  document.getElementById('kpiIn').textContent = pct(passIn, n) + '%';
  document.getElementById('kpiInSub').textContent = passIn + ' / ' + n + ' ผ่านเกณฑ์รับเข้า';
  document.getElementById('kpiStore').textContent = pct(passStore, n) + '%';
  document.getElementById('kpiStoreSub').textContent = passStore + ' / ' + n + ' ผ่านเกณฑ์จัดเก็บ';
  document.getElementById('kpiTime').textContent = avgTotal.toFixed(2) + ' วัน';
  
  const types = ["Matcha","Packaging","Accessories"];
  const typeStats = types.map(t => {
    const sub = rows.filter(r => r.type === t);
    return {
      type: t,
      cnt: sub.length,
      rate: sub.length ? pct(sub.filter(r => r.pass_total).length, sub.length) : null,
      avgStore: sub.length ? sub.reduce((s,r) => s + r.lt_store, 0) / sub.length : null
    };
  }).filter(t => t.cnt > 0);
  
  const otherSub = rows.filter(r => !types.includes(r.type));
  if(otherSub.length){
    typeStats.push({
      type: 'อื่นๆ',
      cnt: otherSub.length,
      rate: pct(otherSub.filter(r => r.pass_total).length, otherSub.length),
      avgStore: otherSub.reduce((s,r) => s + r.lt_store, 0) / otherSub.length
    });
  }
  
  const muted = '#68707e';
  const grid = 'rgba(255,255,255,0.06)';
  const colorMap = { Matcha:'#1baf7a', Packaging:'#6c63d9', Accessories:'#eda100', 'อื่นๆ':'#9aa4b4' };
  
  if(chartTypeInst) chartTypeInst.destroy();
  chartTypeInst = new Chart(document.getElementById('chartType'), {
    type: 'bar',
    data: {
      labels: typeStats.map(t => t.type + ' (' + t.cnt + ')'),
      datasets: [{
        data: typeStats.map(t => t.rate),
        backgroundColor: typeStats.map(t => colorMap[t.type] || '#9aa4b4'),
        borderRadius: 6,
        maxBarThickness: 56
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => ctx.parsed.y + '%' } } },
      scales: {
        y: { min: 0, max: 100, ticks: { color: muted, callback: (v) => v + '%' }, grid: { color: grid } },
        x: { ticks: { color: muted }, grid: { display: false } }
      }
    }
  });
  
  if(chartLeadInst) chartLeadInst.destroy();
  chartLeadInst = new Chart(document.getElementById('chartLeadtime'), {
    type: 'bar',
    data: {
      labels: typeStats.map(t => t.type + ' (' + t.cnt + ')'),
      datasets: [{
        data: typeStats.map(t => Math.round(t.avgStore*100)/100),
        backgroundColor: typeStats.map(t => colorMap[t.type] || '#9aa4b4'),
        borderRadius: 6,
        maxBarThickness: 40
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => ctx.parsed.x + ' วัน' } } },
      scales: {
        x: { min: 0, ticks: { color: muted }, grid: { color: grid } },
        y: { ticks: { color: muted }, grid: { display: false } }
      }
    }
  });
  
  const tbody = document.getElementById('tbody');
  const sorted = rows.slice().sort((a,b) => (b.year - a.year) || (b.week - a.week) || a.lot.localeCompare(b.lot));
  tbody.innerHTML = "";
  sorted.forEach(r => {
    const tr = document.createElement('tr');
    if(!r.pass_total) tr.className = 'fail-row';
    const typeClass = ['Matcha','Packaging','Accessories'].includes(r.type) ? ('type-' + r.type) : 'other';
    tr.innerHTML = `
      <td>W${r.week}</td>
      <td class="mono">${escapeHtml(r.lot)}</td>
      <td style="max-width:240px;white-space:normal;">${escapeHtml(r.product)}</td>
      <td><span class="type-tag ${typeClass}">${escapeHtml(r.type)}</span></td>
      <td class="mono">${escapeHtml(r.to)}</td>
      <td>${r.arrive}</td>
      <td>${r.entered}</td>
      <td>${r.stored}</td>
      <td>${r.lt_in.toFixed(2)}</td>
      <td>${r.lt_store.toFixed(2)}</td>
      <td>${r.sla}</td>
      <td><span class="pill ${r.pass_in ? 'pass' : 'fail'}">${r.pass_in ? 'ผ่าน' : 'ไม่ผ่าน'}</span></td>
      <td><span class="pill ${r.pass_store ? 'pass' : 'fail'}">${r.pass_store ? 'ผ่าน' : 'ไม่ผ่าน'}</span></td>
      <td><span class="pill ${r.pass_total ? 'pass' : 'fail'}">${r.pass_total ? 'ผ่าน' : 'ไม่ผ่าน'}</span></td>
    `;
    tbody.appendChild(tr);
  });
}

async function loadData(){
  const status = document.getElementById('dataStatus');
  try{
    const response = await fetch(DATA_URL, { cache: 'no-store' });
    if(!response.ok) throw new Error(`HTTP ${response.status}`);
    const csv = await response.text();
    
    const parsedCsvData = parseCsv(csv);
    console.log("📥 ดึงข้อมูลดิบสำเร็จ:", parsedCsvData.length, "แถว");
    
    DATA_ROWS = parsedCsvData.map((row, idx) => toDashboardRow(row, idx)).filter(Boolean);
    console.log("✅ กรองข้อมูลสมบูรณ์พร้อมใช้:", DATA_ROWS.length, "แถว");
    
    if (DATA_ROWS.length === 0) {
      throw new Error("ไม่มีข้อมูลที่ผ่านเงื่อนไขการกรองเลย");
    }

    selectLatestPeriod();
    renderYearFilters();
    renderMonthFilters();
    renderWeekFilters();
    update();
    status.innerHTML = '<span class="dot"></span>โหลดข้อมูลล่าสุดแล้ว';
  }catch(error){
    console.error('Unable to load spreadsheet data:', error);
    document.getElementById('rowCountLabel').textContent = 'โหลดข้อมูลไม่สำเร็จ';
    document.getElementById('tbody').innerHTML = '<tr><td colspan="14" class="empty-msg">ไม่สามารถโหลดข้อมูลจาก Google Sheets ได้ หรือรูปแบบข้อมูลหลักไม่ครบถ้วน</td></tr>';
    status.innerHTML = '<span class="dot" style="background:#e34948"></span>โหลดข้อมูลไม่สำเร็จ';
  }
}
loadData();
</script>
