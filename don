function parseCsv(text){
  const records = [];
  let record = [], field = '', quoted = false;
  for(let i = 0; i < text.length; i++){
    const char = text[i];
    if(quoted){
      if(char === '"' && text[i + 1] === '"'){ field += '"'; i++; }
      else if(char === '"'){ quoted = false; }
      else{ field += char; }
    }else if(char === '"'){ quoted = true; }
    else if(char === ','){ record.push(field); field = ''; }
    else if(char === '\n'){
      record.push(field.replace(/\r$/, ''));
      records.push(record);
      record = [];
      field = '';
    }else{ field += char; }
  }
  if(field || record.length){
    record.push(field.replace(/\r$/, ''));
    records.push(record);
  }
  
  // ลบ spacebar ส่วนเกินที่หัวตาราง
  const headers = records.shift()?.map(header => header.trim()) || [];
  console.log("📝 หัวตารางที่อ่านได้จาก CSV:", headers); // ไว้เช็กว่าชื่อคอลัมน์ตรงไหม
  
  return records.map(values => Object.fromEntries(headers.map((header, index) => [header, (values[index] || '').trim()])));
}

function parseSheetDate(value){
  if (!value) return null;
  // ปรับให้รองรับวันที่ที่มีวินาทีด้วย เช่น 15/07/2024 10:30:00
  const match = value.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})(?:\s+(\d{1,2}):(\d{2})(?::(\d{2}))?)?$/);
  if(!match) {
      console.warn("⚠️ รูปแบบวันที่ไม่ตรง (อ่านค่าไม่ได้):", value);
      return null;
  }
  return new Date(Number(match[3]), Number(match[2]) - 1, Number(match[1]), Number(match[4] || 0), Number(match[5] || 0));
}

function formatDate(date){
  if(!date) return '-';
  const pad = value => String(value).padStart(2, '0');
  return `${pad(date.getDate())}/${pad(date.getMonth() + 1)}/${date.getFullYear()}`;
}

function differenceInDays(start, end){
  if (!start || !end) return 0;
  return (end.getTime() - start.getTime()) / 86400000;
}

function isPassing(value){
  return value && value.includes('ผ่าน') && !value.includes('ไม่ผ่าน');
}

function toDashboardRow(row, index){
  const week = Number(row.Week);
  const arriveDate = parseSheetDate(row['วันที่ของมาส่ง']);
  const enteredDate = parseSheetDate(row['วันที่รับเข้าระบบ']);
  const storedDate = parseSheetDate(row['วันที่จัดเก็บ']);
  
  // แจ้งเตือนใน Console ถ้ารายการไหนถูกเตะทิ้ง จะได้รู้สาเหตุ
  if(!Number.isFinite(week) || !row.Month || !row['Lot/Serial Number'] || !arriveDate || !enteredDate || !storedDate) {
      console.log(`❌ แถวที่ ${index + 2} ถูกข้าม เพราะข้อมูลไม่ครบ:`, row);
      return null;
  }
  
  return {
    year: arriveDate.getFullYear(),
    week,
    month: row.Month,
    lot: row['Lot/Serial Number'],
    product: row.Product || '-',
    to: row.To || '-',
    arrive: formatDate(arriveDate),
    entered: formatDate(enteredDate),
    stored: formatDate(storedDate),
    lt_in: differenceInDays(arriveDate, enteredDate),
    lt_store: differenceInDays(enteredDate, storedDate),
    sla: row['วันที่ QA ใช้ตรวจ'] || '-',
    type: row.Type || 'อื่นๆ',
    pass_in: isPassing(row['เกณฑ์รับเข้า'] || ''),
    pass_store: isPassing(row['เกณฑ์จัดเก็บ'] || ''),
    pass_total: isPassing(row['เกณฑ์รวม'] || '')
  };
}

