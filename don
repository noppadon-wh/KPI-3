<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KPI GR to Putaway</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root{
    --bg-0:#0b0e14;
    --bg-1:#11151d;
    --bg-2:#161b26;
    --card-border:rgba(255,255,255,0.06);
    --text-primary:#eef1f6;
    --text-secondary:#9aa4b4;
    --text-muted:#68707e;
    --accent-teal:#1baf7a;
    --accent-purple:#6c63d9;
    --accent-amber:#eda100;
    --accent-red:#e34948;
    --accent-blue:#3987e5;
    --radius:16px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    font-family:'Inter','Noto Sans Thai',sans-serif;
    background:radial-gradient(1200px 600px at 10% -10%, rgba(108,99,217,0.12), transparent 60%),
               radial-gradient(1000px 500px at 90% 0%, rgba(27,175,122,0.10), transparent 55%),
               var(--bg-0);
    color:var(--text-primary);
    min-height:100vh;
    padding:32px 24px 64px;
  }
  .wrap{max-width:1240px;margin:0 auto;}
  .header{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:16px;
    margin-bottom:20px;
  }
  .header h1{
    font-size:26px;
    font-weight:700;
    margin:0 0 6px;
    letter-spacing:-0.02em;
  }
  .header p{
    margin:0;
    color:var(--text-secondary);
    font-size:14px;
  }
  .badge{
    display:inline-flex;
    align-items:center;
    gap:6px;
    background:rgba(27,175,122,0.12);
    color:#4fd8a8;
    border:1px solid rgba(27,175,122,0.28);
    padding:6px 14px;
    border-radius:999px;
    font-size:12.5px;
    font-weight:600;
  }
  .dot{width:6px;height:6px;border-radius:50%;background:#4fd8a8;}
  .filter-panel{
    background:linear-gradient(180deg, var(--bg-2), var(--bg-1));
    border:1px solid var(--card-border);
    border-radius:var(--radius);
    padding:16px 20px;
    margin-bottom:20px;
  }
  .filter-row{
    display:flex;
    align-items:center;
    gap:10px;
    flex-wrap:wrap;
  }
  .filter-row + .filter-row{margin-top:12px;}
  .filter-label{
    font-size:12.5px;
    color:var(--text-muted);
    font-weight:600;
    min-width:56px;
    text-transform:uppercase;
    letter-spacing:0.03em;
  }
  .chip{
    appearance:none;
    border:1px solid var(--card-border);
    background:var(--bg-1);
    color:var(--text-secondary);
    font-family:inherit;
    font-size:13px;
    font-weight:500;
    padding:6px 14px;
    border-radius:999px;
    cursor:pointer;
    transition:all .15s ease;
    white-space:nowrap;
  }
  .chip:hover{border-color:var(--text-muted);color:var(--text-primary);}
  .chip.active{
    background:rgba(27,175,122,0.16);
    border-color:rgba(27,175,122,0.5);
    color:#4fd8a8;
  }
  .chip.active.month-active{
