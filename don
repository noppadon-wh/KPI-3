  tbody tr:hover{background:rgba(255,255,255,0.02);}
  tbody tr.fail-row td:first-child{box-shadow:inset 3px 0 0 var(--accent-red);}
  .mono{font-family:'Inter',monospace;font-size:12px;color:var(--text-secondary);}
  .pill{
    display:inline-block;
    padding:3px 10px;
    border-radius:999px;
    font-size:11.5px;
    font-weight:600;
  }
  .pill.pass{background:rgba(27,175,122,0.14);color:#4fd8a8;}
  .pill.fail{background:rgba(227,73,72,0.14);color:#f18685;}
  .type-tag{
    display:inline-block;
    padding:3px 10px;
    border-radius:6px;
    font-size:11.5px;
    font-weight:600;
  }
  .type-Matcha{background:rgba(27,175,122,0.14);color:#4fd8a8;}
  .type-Packaging{background:rgba(108,99,217,0.16);color:#a9a0f0;}
  .type-Accessories{background:rgba(237,161,0,0.14);color:#f4c05a;}
  .type-tag.other{background:rgba(154,164,180,0.14);color:#c3c9d4;}
  .foot-note{
    font-size:12px;
    color:var(--text-muted);
    margin-top:20px;
    line-height:1.6;
    border-top:1px solid var(--card-border);
    padding-top:16px;
  }
  @media(max-width:900px){
    .kpi-grid{grid-template-columns:repeat(2,1fr);}
    .charts-grid{grid-template-columns:1fr;}
  }
</style>
